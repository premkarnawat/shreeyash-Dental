# ─────────────────────────────────────────────────────────────────
# Shree Yash Dental — AI Agents Environment Variables
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3001

# Your Render.com URL after deployment (no trailing slash)
# Example: https://shreeyash-dental-agents.onrender.com
BASE_URL=https://shreeyash-dental-agents.onrender.com

# ── Neon PostgreSQL ───────────────────────────────────────────────
# SAME database as your frontend — get from neon.tech
# Format: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── Groq AI (FREE — no credit card needed) ────────────────────────
# Sign up at: https://console.groq.com → API Keys → Create API Key
# Key starts with: gsk_
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio ────────────────────────────────────────────────────────
# Sign up at: https://twilio.com (free $15 credit)
# Get from: https://console.twilio.com → Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Voice: Phone number you bought in Twilio Console → Phone Numbers → Buy
# Example: +14155551234
TWILIO_VOICE_NUMBER=+14155551234

# WhatsApp: Free sandbox number (no approval needed for testing)
# Always: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Clinic Info ───────────────────────────────────────────────────
CLINIC_NAME=Shree Yash Multispeciality Dental Clinic
DOCTOR_NAME=Dr. Sagar Jadhav
CLINIC_PHONE=+919850044913

# ── Cron Job Secret ───────────────────────────────────────────────
# Used to protect the /jobs/reminders endpoint
# Set the same value on cron-job.org when creating the job
CRON_SECRET=cron-shreeyash-2025
